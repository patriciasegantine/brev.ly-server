# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
PORT=3333
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
# Connection String (matches docker-compose.yml credentials)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=brevly
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}"

# -----------------------------------------------------------------------------
# Storage Configuration (Cloudflare R2)
# -----------------------------------------------------------------------------
# Leave empty for local development
# Fill these values when setting up CSV export functionality
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_ACCESS_KEY_ID=""
CLOUDFLARE_SECRET_ACCESS_KEY=""
CLOUDFLARE_BUCKET=""
CLOUDFLARE_PUBLIC_URL=""

# -----------------------------------------------------------------------------
# Setup Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. The .env file is git-ignored and should never be committed
# 3. These default values work with docker-compose.yml for local development
# -----------------------------------------------------------------------------
