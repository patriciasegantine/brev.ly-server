# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
PORT=3333
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
# Connection String (matches docker-compose.yml credentials)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=brevly
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/brevly"

# -----------------------------------------------------------------------------
# Storage Configuration (Cloudflare R2)
# -----------------------------------------------------------------------------
# Leave empty for local development
# Fill these values when setting up CSV export functionality
CLOUDFLARE_ACCOUNT_ID="your_account_id"
CLOUDFLARE_ACCESS_KEY_ID="your_access_key_id"
CLOUDFLARE_SECRET_ACCESS_KEY="your_secret_access_key"
CLOUDFLARE_BUCKET="your_bucket_name"
CLOUDFLARE_PUBLIC_URL="https:/your_url.dev"

# -----------------------------------------------------------------------------
# Setup Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. The .env file is git-ignored and should never be committed
# 3. These default values work with docker-compose.yml for local development
# -----------------------------------------------------------------------------
