{
  "name": "brev.ly-server",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "index.js",
  "keywords": [],
  "author": "Patricia Segantine",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/patriciasegantine/Brev.ly.git"
  },
  "scripts": {
    "dev": "tsx watch --env-file .env src/server.ts",
    "build": "tsup src",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "npm run test:db:prepare && npm run test:run",
    "test:db:prepare": "dotenv -e .env.test -- tsx src/test/prepare-db.ts && dotenv -e .env.test -- drizzle-kit migrate",
    "test:run": "dotenv -e .env.test -- vitest run",
    "pre-pr": "npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.6",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.5"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.937.0",
    "@aws-sdk/lib-storage": "^3.1037.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.2.1",
    "@fastify/swagger": "^9.5.2",
    "@fastify/swagger-ui": "^5.2.3",
    "@scalar/fastify-api-reference": "^1.55.3",
    "dotenv": "^17.2.3",
    "drizzle-orm": "1.0.0-beta.21",
    "fastify": "5.8.5",
    "fastify-type-provider-zod": "^4.0.2",
    "postgres": "^3.4.7",
    "uuidv7": "^1.1.0",
    "zod": "^3.24.1"
  }
}
